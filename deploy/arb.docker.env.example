# Copy to repo root as arb.docker.env (optional overrides for Docker)
# Secrets: still use %USERPROFILE%\.hermes\.env on the HOST — mounted at /data/.env
#
#   copy deploy\arb.docker.env.example arb.docker.env

# Paper trading (defaults — safe)
# ARB_STUDY_MODE=false
# ARB_EXEC_MODE=paper
# ARB_DRY_RUN=true
# ARB_KILL_SWITCH=false
# ARB_ALLOW_LIVE=false

# Scanner
# ARB_MIN_EDGE_BPS=30
# ARB_TAKER_FEE_BPS=10
# ARB_VERIFY_TOP_N=40
# ARB_WORKER_SCAN_SEC=300
# ARB_WORKER_LOOP_SEC=600
# ARB_WORKER_TRADE_LIMIT=3

# Never commit real keys. Put in %USERPROFILE%\.hermes\.env instead:
# XAI_API_KEY=...
# POLYMARKET_PRIVATE_KEY=...   # live only — not needed for paper
