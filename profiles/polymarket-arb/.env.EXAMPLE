# Copy secrets to ~/.hermes/.env (chmod 600). Never commit real keys.

# --- Intelligence (Grok / xAI) — offline postmortem only ---
# XAI_API_KEY=xai-...
# ARB_GROK_MODEL=grok-3-mini
# ARB_LLM_DAILY_TOKEN_BUDGET=100000
# ARB_WORKER_GROK=false          # set true to enable Grok on daily worker postmortem

# --- Scanner / study ---
# ARB_SCAN_SOURCE=events          # events (default) | markets
# ARB_GAMMA_MAX_OFFSET=2000
# ARB_MIN_EDGE_BPS=30
# ARB_TAKER_FEE_BPS=10
# ARB_VERIFY_TOP_N=40
# ARB_LIQUID_SCAN_LIMIT=400       # alpha command: top liquid CLOB check
# ARB_NEAR_MISS_BPS=15
# ARB_DRY_RUN=true
# ARB_STUDY_MODE=true
# ARB_EXEC_MODE=paper            # paper | live | disabled
# ARB_KILL_SWITCH=false
# ARB_MAX_POSITION_USD=25
# ARB_MAX_OPEN_POSITIONS=5
# ARB_MAX_DAILY_TRADES=20
# ARB_MAX_DAILY_LOSS_USD=50
# ARB_PAPER_SLIPPAGE_BPS=10
# ARB_ALLOW_LIVE=false
# ARB_WS_ENABLED=true
# ARB_WS_WATCH_SEC=30
# ARB_WS_MAX_ASSETS=40
# ARB_WS_SEED_REST=true
# ARB_WORKER_SCAN_SEC=300
# ARB_WORKER_LOOP_SEC=900
# ARB_WORKER_PAPER=true
# ARB_MIN_BOOK_DEPTH=5
# ARB_VERIFY_TOP_N=25
# ARB_ALERT_ON_VERIFIED=true
# ARB_STATE_DIR=                 # optional override; default under HERMES_HOME

# --- Live CLOB (py-clob-client-v2) — all gates required ---
# pip install 'hermes-agent[polymarket-arb]'   # or: pip install py-clob-client-v2
# POLYMARKET_PRIVATE_KEY=0x...
# POLYMARKET_FUNDER=0x...        # Magic/proxy wallet funder if needed
# POLYMARKET_SIGNATURE_TYPE=1    # 0=EOA, 1=Magic/email, 2=browser wallet
# CLOB_API_KEY=
# CLOB_SECRET=
# CLOB_PASS_PHRASE=
# Then: ARB_ALLOW_LIVE=true ARB_EXEC_MODE=live ARB_DRY_RUN=false ARB_STUDY_MODE=false
