# Phase 5 worker defaults — copy values into environment or systemd EnvironmentFile.
# VPS profile: deploy/vps.env.example (tuned for alpha + WS)
# Secrets stay in .env; these are behavioral schedules only.

# Scanner
ARB_SCAN_SOURCE=events
ARB_GAMMA_MAX_OFFSET=2000
ARB_MIN_EDGE_BPS=30
ARB_TAKER_FEE_BPS=10
ARB_VERIFY_TOP_N=40
ARB_LIQUID_SCAN_LIMIT=400
ARB_NEAR_MISS_BPS=15
ARB_ALPHA_WORKERS=8

ARB_WORKER_SCAN_SEC=300
ARB_WORKER_LOOP_SEC=600
ARB_WORKER_RECONCILE_SEC=3600
ARB_WORKER_POSTMORTEM_SEC=86400
ARB_WORKER_SCAN_LIMIT=
ARB_WORKER_TRADE_LIMIT=3
ARB_WORKER_USE_WS=true
ARB_WORKER_WS_SEC=20
ARB_WORKER_PAPER=true
ARB_WORKER_POSTMORTEM=true
ARB_WORKER_HEARTBEAT_SEC=60

# Money-loop safety (paper by default)
ARB_STUDY_MODE=false
ARB_EXEC_MODE=paper
ARB_DRY_RUN=true
ARB_KILL_SWITCH=false
ARB_ALLOW_LIVE=false
# ARB_WORKER_GROK=false
# XAI_API_KEY=          # for --grok / ARB_WORKER_GROK only
# POLYMARKET_PRIVATE_KEY=  # live only
