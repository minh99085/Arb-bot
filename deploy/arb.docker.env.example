# Copy to repo root as arb.docker.env (optional overrides for Docker)
# Secrets: still use %USERPROFILE%\.hermes\.env on the HOST — mounted at /data/.env
#
#   copy deploy\arb.docker.env.example arb.docker.env

# Execution safety (defaults — scanner/shadow-first, safe)
# ARB_SAFETY_MODE=scan_only          # scan_only | shadow | paper_execution | live
# ARB_PAPER_EXECUTION_ENABLED=false  # separate gate for simulated fills
# ARB_STUDY_MODE=true
# ARB_EXEC_MODE=disabled
# ARB_DRY_RUN=true
# ARB_KILL_SWITCH=false
# ARB_ALLOW_LIVE=false
# ARB_SELF_TUNE=false                # stale self_tune.json is ignored when off

# Scanner
# ARB_MIN_EDGE_BPS=30
# ARB_TAKER_FEE_BPS=10
# ARB_VERIFY_TOP_N=40
# ARB_WORKER_SCAN_SEC=300
# ARB_WORKER_LOOP_SEC=600
# ARB_WORKER_TRADE_LIMIT=3

# Opt in to simulated paper fills (uncomment ALL three):
# ARB_SAFETY_MODE=paper_execution
# ARB_PAPER_EXECUTION_ENABLED=true
# ARB_STUDY_MODE=false

# Never commit real keys. Put in %USERPROFILE%\.hermes\.env instead:
# XAI_API_KEY=...
# POLYMARKET_PRIVATE_KEY=...   # live only — not needed for paper
