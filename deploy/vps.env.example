# Polymarket arb worker — SCANNER / SHADOW-FIRST defaults (safe).
# Copy to ~/.hermes/profiles/polymarket-arb/worker.env or use via START.ps1.
#
# Out of the box this ONLY scans, verifies against CLOB books, and logs.
# No paper fills, no live orders, no self-tuning. Every form of execution is
# an explicit opt-in (see the two commented blocks at the bottom).

# --- Execution safety (master switch) ---
ARB_SAFETY_MODE=scan_only          # scan_only | shadow | paper_execution | live
ARB_PAPER_EXECUTION_ENABLED=false  # separate gate; must be true for simulated fills
ARB_STUDY_MODE=true                # extra guard: blocks any execution
ARB_EXEC_MODE=disabled             # paper | live | disabled
ARB_DRY_RUN=true
ARB_KILL_SWITCH=false
ARB_ALLOW_LIVE=false

# --- Autonomous learning: OFF (does not apply stale self_tune.json) ---
ARB_SELF_TUNE=false

# --- Scanner: real CLOB verification only ---
ARB_SCAN_SOURCE=events
ARB_GAMMA_MAX_OFFSET=2000
ARB_PAPER_REALISTIC=true
ARB_PAPER_GAMMA_FALLBACK=false
ARB_MIN_EDGE_BPS=25
ARB_PAPER_MIN_EDGE_BPS=15
ARB_TAKER_FEE_BPS=10
ARB_VERIFY_TOP_N=50
ARB_MIN_BOOK_DEPTH=2
ARB_LIQUID_SCAN_LIMIT=800
ARB_NEAR_MISS_BPS=30
ARB_ALPHA_WORKERS=12
ARB_ALERT_ON_VERIFIED=true

# --- Risk caps (only used once execution is explicitly enabled) ---
ARB_MAX_POSITION_USD=15
ARB_MAX_OPEN_POSITIONS=10
ARB_MAX_DAILY_TRADES=50
ARB_MAX_DAILY_LOSS_USD=75
ARB_PAPER_SLIPPAGE_BPS=15

# --- Worker cadence (scan + shadow observations + reconcile report) ---
ARB_WS_ENABLED=true
ARB_WS_WATCH_SEC=15
ARB_WS_MAX_ASSETS=80
ARB_WS_SEED_REST=true
ARB_WORKER_SCAN_SEC=120
ARB_WORKER_LOOP_SEC=120
ARB_WORKER_RECONCILE_SEC=900
ARB_WORKER_POSTMORTEM_SEC=21600
ARB_WORKER_SELF_TUNE_SEC=1800
ARB_WORKER_TRADE_LIMIT=10
ARB_WORKER_USE_WS=true
ARB_WORKER_WS_SEC=12
ARB_WORKER_POSTMORTEM=true

# ---------------------------------------------------------------------------
# OPT-IN: simulated paper execution (uncomment ALL three). Sell bundles remain
# UNSUPPORTED. Expected PnL is never auto-realized; fills stay UNRESOLVED.
# ARB_SAFETY_MODE=paper_execution
# ARB_PAPER_EXECUTION_ENABLED=true
# ARB_STUDY_MODE=false
#
# OPT-IN: live execution (a later phase — every gate below required + a key).
# ARB_SAFETY_MODE=live
# ARB_ALLOW_LIVE=true
# ARB_EXEC_MODE=live
# ARB_DRY_RUN=false
# ARB_STUDY_MODE=false
# POLYMARKET_PRIVATE_KEY=0x...   # in ~/.hermes/.env, never committed
# ---------------------------------------------------------------------------
