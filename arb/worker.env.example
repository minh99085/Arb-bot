# Phase 5 worker defaults — copy values into environment or systemd EnvironmentFile.
# Secrets stay in .env; these are behavioral schedules only.

ARB_WORKER_SCAN_SEC=300
ARB_WORKER_LOOP_SEC=900
ARB_WORKER_RECONCILE_SEC=3600
ARB_WORKER_POSTMORTEM_SEC=86400
ARB_WORKER_SCAN_LIMIT=
ARB_WORKER_TRADE_LIMIT=5
ARB_WORKER_USE_WS=false
ARB_WORKER_WS_SEC=15
ARB_WORKER_PAPER=true
ARB_WORKER_POSTMORTEM=true
ARB_WORKER_HEARTBEAT_SEC=60

# Money-loop safety (paper by default)
ARB_STUDY_MODE=false
ARB_EXEC_MODE=paper
ARB_DRY_RUN=true
ARB_KILL_SWITCH=false
ARB_ALLOW_LIVE=false
